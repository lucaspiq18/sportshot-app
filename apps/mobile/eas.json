{
  "$schema": "https://raw.githubusercontent.com/expo/eas-cli/main/packages/eas-cli/schema/eas.schema.json",
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local",
    "requireCommit": false
  },
  "build": {
    "base": {
      "node": "20.0.0"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "REEMPLAZAR_CON_CLERK_KEY_DEV"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sportshot-app-production.up.railway.app",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "REEMPLAZAR_CON_CLERK_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sportshot-app-production.up.railway.app",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "REEMPLAZAR_CON_CLERK_KEY"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "lucaspiq18@gmail.com",
        "ascAppId": "REEMPLAZAR_CON_ASC_APP_ID",
        "appleTeamId": "REEMPLAZAR_CON_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
