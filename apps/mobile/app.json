{
  "expo": {
    "name": "SportShot",
    "slug": "sportshot",
    "owner": "sportshot-18",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "sportshot",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0f14",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0a0f14",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.sportshot.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["sportshot"],
        "NSPhotoLibraryUsageDescription": "SportShot necesita acceso a tus fotos para subir imágenes de eventos deportivos.",
        "NSCameraUsageDescription": "SportShot necesita acceso a la cámara para fotografiar eventos."
      }
    },
    "android": {
      "package": "app.sportshot.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f14"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "sportshot" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "SportShot necesita acceso a tus fotos para subir imágenes de eventos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7EC8E3"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bd7f5185-745c-43af-9d92-19c51169b01e"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/bd7f5185-745c-43af-9d92-19c51169b01e"
    }
  }
}
